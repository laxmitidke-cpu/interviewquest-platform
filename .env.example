# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="AIzaSyA1j6ifETf0ycmvkVx-pnO96iZsiVzT9bM"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: Optional PostgreSQL connection URI.
# If provided, the app will connect to PostgreSQL. Defaults to file-based secure local system.
#DATABASE_URL="postgresql://user:password@localhost:5432/interviewquest"
DATABASE_URL="postgresql://user:password@https://cloudflare-workers-autoconfig-interviewquest-platform.laxmitidke-ai-1.workers.dev/interviewquest"
